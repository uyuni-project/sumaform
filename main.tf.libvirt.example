terraform {
 required_version = ">= 1.6.0"
 required_providers {
   libvirt = {
     source = "dmacvicar/libvirt"
     version = "0.8.3"
   }
 }
}

// On same OSes, Libvirtd has moved from the old, monolithic, daemon (libvirtd) to a modular approach.
// If you need or want to enable the modular daemons, follow the 5 steps in the "Switching to modular daemons" section
// at https://libvirt.org/daemons.html#switching-to-modular-daemons to do so.
provider "libvirt" {
  // uri = "qemu:///system?socket=/run/libvirt/virtqemud-sock" for the modular daemons.
  // Or run systemctl start virtproxyd.socket to maintain backcompatibility with the UNIX socket path of the monolithic daemon.
  uri = "qemu:///system"
}

module "base" {
  source = "./modules/base"

  // Set SUSE Customer Center credentials here if you have some
  // cc_username = ""
  // cc_password = ""
  product_version = "uyuni-master"

  // optional parameters with defaults below
  // use_avahi = true
  // name_prefix = "" // if you use name_prefix, make sure to update the server_configuration for clients/minions below
  // timezone = "Europe/Berlin"
  // use_ntp = true

  // provider_settings = {
  //   network_name = "default" // change to null if you add a bridge below
  //   additional_network = null
  //   bridge = null
  //   pool = "default"
  // }

  images = ["opensuse156o", "tumbleweedo"]
}

module "server" {
  source = "./modules/server_containerized"
  base_configuration = module.base.configuration

  name = "server"
  // see modules/server_containerized/variables.tf for possible values

  // connect_to_additional_network = true
  // if you want to use two networks

  // If you want to run the containers on podman.
  // runtime = "podman"

  // To override the default container repository containing the images
  // container_repository = "registry.opensuse.org/systemsmanagement/uyuni/master/servercontainer/containers/uyuni"

  // To override the default images names for Server and Database containers
  // container_image = "server"
  // db_container_image = "server-postgresql"

  // To define a specific container image tag to install
  // container_tag = 
}

module "minion" {
  source = "./modules/minion"
  base_configuration = module.base.configuration

  name = "minion"
  image = "opensuse156o"
  server_configuration = module.server.configuration
  // see modules/minion/variables.tf for possible values
}
